#!/usr/bin/env bash

set -o errexit
set -o nounset
set -o pipefail
set -o xtrace

uv run ruff check . --fix --unsafe-fixes
uv run ruff format .

if [ "${SKIP_NOTEBOOKS:-false}" == "true" ]; then
  echo "Skipping notebooks"
  exit 0
fi

uv run python scripts/clean_notebooks.py -i examples/ -o inplace
